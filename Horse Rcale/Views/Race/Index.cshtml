@model List<Horse_Rcale.Models.Horse>

<link rel="stylesheet" href="~/css/race.css" />

<div class="race-page">
    <div class="race-header-row">
        <div class="race-page-title">Horse Racing Simulator</div>
    </div>

    <section class="race-main">
        <aside class="panel horses-panel">
            <div class="panel-header">
                <div class="horses-header-left">
                    <h2>Horses <span id="horses-count">@((Model?.Count ?? 0))</span></h2>
                    <button id="horse-add" class="horse-add">+</button>
                    <button id="horse-remove" class="horse-remove">-</button>
                </div>
            </div>

            <div class="horses-list" id="horses-list">
                @if (Model == null || !Model.Any())
                {
                    <p class="empty-state">No horses yet. Choose a mode and create some to begin.</p>
                }
                else
                {
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var horse = Model[i];
                        var color = GetHorseColor(i);

                        <div class="horse-card">
                            <div class="horse-card-header">
                                <span class="horse-color-swatch" style="background-color:@color;"></span>
                                <div class="horse-card-title">
                                    <div class="horse-name">@horse.Name</div>
                                    <div class="horse-meta">Horse @(i + 1)</div>
                                </div>
                            </div>

                            <div class="horse-stats">
                                <div class="horse-stat">
                                    <span class="horse-stat-label">Speed</span>
                                    <div class="horse-stat-bar">
                                        <div class="horse-stat-bar-fill speed" style="width:@GetPercent(horse.Speed)%"></div>
                                    </div>
                                </div>

                                <div class="horse-stat">
                                    <span class="horse-stat-label">Stamina</span>
                                    <div class="horse-stat-bar">
                                        <div class="horse-stat-bar-fill stamina" style="width:@GetPercent(horse.Stamina)%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="horses-actions">
                <form method="post" action="/Race/ResetCustom">
                    <button type="submit" class="btn-ghost">Reset Race</button>
                </form>
            </div>
        </aside>

        <section class="panel track-panel">
            <div class="full-racetrack">
                <div class="panel-header">
                    <h2>Race Track</h2>
                    
                </div>

                <div class="race-track">
                    @if (Model == null || !Model.Any())
                    {
                        <p class="empty-state">No horses available. Add some to start a race.</p>
                    }
                    else
                    {
                        <div class="race-track-layout">
                          

                            <div class="race-track-lanes">
                                @for (int i = 0; i < Model.Count; i++)
                                {
                                    var horse = Model[i];
                                    var color = GetHorseColor(i);

                                    <div class="race-lane">
                                        <div class="race-lane-line"></div>

                                        <div class="horse"
                                             data-id="@horse.Id"
                                             data-name="@horse.Name"
                                             data-speed="@horse.Speed"
                                             data-stamina="@horse.Stamina"
                                             style="--horse-color:@color;">
                                            <span class="horse-dot"></span>
                                            <span class="horse-label">@horse.Name</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="race-main-action">
                    <button type="button" class="btn-primary" onclick="startRace()">Start Race</button>
                </div>
            </div>
        </section>
    </section>
</div>

<script src="~/js/race.js"></script>
<script>
    const horsesList = document.getElementById('horses-list');
    const horsesCount = document.getElementById('horses-count');
    const horseAddBtn = document.getElementById('horse-add');
    const horseRemoveBtn = document.getElementById('horse-remove');

    let horseIndex = horsesList.children.length; // текущий индекс

    // Функция для генерации цвета (как в Razor)
    function getHorseColor(index) {
        const colors = ["#0f766e", "#f97316", "#3b82f6", "#e11d48", "#6366f1", "#22c55e"];
        return colors[index % colors.length];
    }

    // Функция для случайных speed/stamina
    function randomStat() {
        return Math.floor(Math.random() * 10) + 1; // 1-10
    }

    // Добавление лошади
    horseAddBtn.addEventListener('click', () => {
        if (window.__raceRunning) return;

        horseIndex = horsesList.querySelectorAll('.horse-card').length;
        horseIndex++;

        const color = getHorseColor(horseIndex - 1);
        const speed = randomStat();
        const stamina = randomStat();

        const defaultName = `Horse ${horseIndex}`;
        const value = prompt("Horse name:", defaultName);
        const horseName = (value ?? "").trim().length ? (value ?? "").trim() : defaultName;

        // If list starts with an empty-state, remove it when adding the first horse.
        const horsesEmpty = horsesList.querySelector('.empty-state');
        if (horsesEmpty) horsesEmpty.remove();

        const horseCard = document.createElement('div');
        horseCard.classList.add('horse-card');
        horseCard.dataset.id = horseIndex;

        horseCard.innerHTML = `
            <div class="horse-card-header">
                <span class="horse-color-swatch" style="background-color:${color};"></span>
                <div class="horse-card-title">
                    <div class="horse-name">${horseName}</div>
                    <div class="horse-meta">Horse ${horseIndex}</div>
                </div>
            </div>
            <div class="horse-stats">
                <div class="horse-stat">
                    <span class="horse-stat-label">Speed</span>
                    <div class="horse-stat-bar">
                        <div class="horse-stat-bar-fill speed" style="width:${speed*10}%"></div>
                    </div>
                </div>
                <div class="horse-stat">
                    <span class="horse-stat-label">Stamina</span>
                    <div class="horse-stat-bar">
                        <div class="horse-stat-bar-fill stamina" style="width:${stamina*10}%"></div>
                    </div>
                </div>
            </div>
        `;

        horsesList.appendChild(horseCard);

        // Ensure track lanes exist (if the track was initially empty).
        const raceTrack = document.querySelector('.race-track');
        let lanes = document.querySelector('.race-track-lanes');
        if (!lanes && raceTrack) {
            const existingLayout = raceTrack.querySelector('.race-track-layout');
            if (existingLayout) {
                lanes = existingLayout.querySelector('.race-track-lanes');
            }

            if (!lanes) {
                const emptyState = raceTrack.querySelector('.empty-state');
                if (emptyState) emptyState.remove();

                const layout = document.createElement('div');
                layout.className = 'race-track-layout';

                lanes = document.createElement('div');
                lanes.className = 'race-track-lanes';

                layout.appendChild(lanes);
                raceTrack.appendChild(layout);
            }
        }

        // Add matching horse to the racetrack.
        if (lanes) {
            const lane = document.createElement('div');
            lane.className = 'race-lane';

            const line = document.createElement('div');
            line.className = 'race-lane-line';

            const horse = document.createElement('div');
            horse.className = 'horse';
            horse.dataset.id = horseIndex;
            horse.dataset.name = horseName;
            horse.dataset.speed = speed;
            horse.dataset.stamina = stamina;
            horse.style.setProperty('--horse-color', color);

            horse.innerHTML = `
                <span class="horse-dot"></span>
                <span class="horse-label">${horseName}</span>
            `;

            lane.appendChild(line);
            lane.appendChild(horse);
            lanes.appendChild(lane);
        }

        if (horsesCount) horsesCount.textContent = horseIndex;
    });

    // Удаление последней лошади
    horseRemoveBtn.addEventListener('click', () => {
        if (window.__raceRunning) return;

        const horseCards = horsesList.querySelectorAll('.horse-card');
        if (horseCards.length === 0) return;

        // Remove last horse card (sidebar).
        horseCards[horseCards.length - 1].remove();

        // Remove matching horse lane (track).
        const raceLanes = document.querySelectorAll('.race-track-lanes .race-lane');
        if (raceLanes.length) {
            raceLanes[raceLanes.length - 1].remove();
        }

        horseIndex = horsesList.querySelectorAll('.horse-card').length;
        if (horsesCount) horsesCount.textContent = horseIndex;

        // If nothing is left, show empty-states again.
        if (horseIndex === 0) {
            const horsesEmpty = document.createElement('p');
            horsesEmpty.className = 'empty-state';
            horsesEmpty.textContent = 'No horses yet. Choose a mode and create some to begin.';
            horsesList.appendChild(horsesEmpty);

            const raceTrack = document.querySelector('.race-track');
            const layout = raceTrack ? raceTrack.querySelector('.race-track-layout') : null;
            if (layout) layout.remove();

            if (raceTrack) {
                const trackEmpty = document.createElement('p');
                trackEmpty.className = 'empty-state';
                trackEmpty.textContent = 'No horses available. Add some to start a race.';
                raceTrack.appendChild(trackEmpty);
            }
        }
    });
</script>
@functions {
    private static string GetHorseColor(int index)
    {
        string[] colors = { "#0f766e", "#f97316", "#3b82f6", "#e11d48", "#6366f1", "#22c55e" };
        return colors[index % colors.Length];
    }

    private static int GetPercent(int value)
    {
        if (value < 0) value = 0;
        if (value > 10) value = 10;
        return value * 10;
    }
}