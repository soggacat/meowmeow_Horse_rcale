@model List<Horse_Rcale.Models.Horse>

<link rel="stylesheet" href="~/css/race.css" />

<!-- ПАНЕЛЬ РЕЖИМОВ -->
<div class="mode-panel">
    <a href="/Race/SetRandomMode">🎲 Случайные лошади</a>
    <a href="/Race/SetCustomMode">🐎 Своя конюшня</a>
</div>

<!-- ВЕРХНЯЯ ПАНЕЛЬ -->
<div class="top-panel">
    <div id="top-track"></div>
</div>

<div class="layout">

    <!-- ЛОГ -->
    <div class="log-panel">
        <h4>Позиции</h4>
        <ul id="log"></ul>
    </div>

    <!-- ТРЕК -->
    <div class="track">
        @if (!Model.Any())
        {
            <p>Нет лошадей для гонки</p>
        }
        else
        {
            foreach (var horse in Model)
            {
                <div class="lane">
                    <div class="horse"
                         data-id="@horse.Id"
                         data-name="@horse.Name"
                         data-speed="@horse.Speed"
                         data-stamina="@horse.Stamina">
                        🐎 @horse.Name
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="controls">
    <button onclick="startRace()">Старт</button>
    <a href="/Race/Create">Создать лошадь</a>

    <form method="post" action="/Race/ResetCustom" style="display:inline;">
        <button type="submit">Сброс конюшни</button>
    </form>
</div>

<script src="~/js/race.js"></script>